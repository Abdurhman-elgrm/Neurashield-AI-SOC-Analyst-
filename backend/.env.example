# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="SOC SaaS"
APP_VERSION="2.0.0"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─── API ──────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://soc_user:changeme@localhost:5432/soc_saas
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=changeme_generate_different_secret_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_ATTEMPTS=10
RATE_LIMIT_API_REQUESTS=300
RATE_LIMIT_INGEST_EVENTS=10000

# ─── Workers ──────────────────────────────────────────────────────────────────
WORKER_STREAM_BLOCK_MS=5000
WORKER_CLAIM_IDLE_MS=30000
WORKER_MAX_RETRY=3
